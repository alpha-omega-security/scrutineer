{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "recon report",
  "description": "A short, read-only map of input-processing subsystems consumed by threat-model when it proposes repository scan-config focus areas.",
  "type": "object",
  "required": ["focus_areas", "notes"],
  "additionalProperties": false,
  "properties": {
    "focus_areas": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["name", "surface", "paths"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "surface": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "paths": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 300
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  }
}
