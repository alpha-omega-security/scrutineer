{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/andrew/security-research/defs.schema.json",
  "title": "Shared vocabulary for spec-* schemas",
  "description": "Common $defs referenced by spec-json, exposure, route, health, alternatives, disclose, migrate, fixaudit, and interchange schemas. Change an enum here and every consumer moves together.",

  "$defs": {
    "markdown": {
      "type": "string",
      "contentMediaType": "text/markdown",
      "description": "GitHub-flavoured markdown. May contain fenced code blocks, tables, and links."
    },

    "severity": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low"]
    },

    "confidence": {
      "type": "string",
      "enum": ["High", "Medium", "Low"]
    },

    "sink_class": {
      "type": "string",
      "description": "Canonical sink class from spec-deep Phase 1.",
      "enum": [
        "Code execution",
        "Command execution",
        "File operations",
        "Path handling",
        "Archive extraction",
        "Deserialisation",
        "Template",
        "Network",
        "Validation",
        "Cryptography",
        "Memory safety",
        "Shared mutable state",
        "Concurrency",
        "Resource consumption",
        "Reflection",
        "Round-trip integrity"
      ]
    },

    "sink_id":    { "type": "string", "pattern": "^S[0-9]+$" },
    "finding_id": { "type": "string", "pattern": "^F[0-9]+$" },

    "step": {
      "type": "integer",
      "minimum": 1,
      "maximum": 6,
      "description": "spec-deep Phase 2 step. 1=trace, 2=boundary, 3=validate, 4=prior_art, 5=reach, 6=rate."
    },

    "cwe": {
      "type": "string",
      "pattern": "^CWE-[0-9]+$"
    },

    "cve": {
      "type": "string",
      "pattern": "^CVE-[0-9]{4}-[0-9]{4,}$"
    },

    "purl": {
      "type": "string",
      "pattern": "^pkg:[a-z0-9.+-]+/",
      "description": "Package URL per github.com/package-url/purl-spec."
    },

    "cvss": {
      "type": "object",
      "required": ["version", "vector", "score"],
      "additionalProperties": false,
      "properties": {
        "version": { "type": "string", "enum": ["3.0", "3.1", "4.0"] },
        "vector":  { "type": "string", "pattern": "^CVSS:[34]\\.[01]/" },
        "score":   { "type": "number", "minimum": 0, "maximum": 10 }
      }
    },

    "reference": {
      "type": "object",
      "required": ["url"],
      "additionalProperties": false,
      "properties": {
        "url":     { "type": "string", "format": "uri" },
        "summary": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "enum": ["advisory", "issue", "patch", "permalink", "exploit", "article", "discussion"] }
        }
      }
    },

    "vex_status": {
      "type": "string",
      "enum": ["affected", "not_affected", "fixed", "under_investigation"]
    },

    "vex_justification": {
      "type": "string",
      "description": "CSAF/VEX not_affected justification codes.",
      "enum": [
        "component_not_present",
        "vulnerable_code_not_present",
        "vulnerable_code_not_in_execute_path",
        "vulnerable_code_cannot_be_controlled_by_adversary",
        "inline_mitigations_already_exist"
      ]
    },

    "health": {
      "type": "string",
      "description": "Repository maintenance health.",
      "enum": ["active", "stale", "abandoned", "zombie"]
    },

    "resolution": {
      "type": "string",
      "description": "How a finding gets resolved.",
      "enum": ["fix", "migrate", "workaround", "adopt", "wontfix"]
    },

    "maintainer_status": {
      "type": "string",
      "enum": ["active", "active-elsewhere", "abandoned", "unknown"]
    },

    "finding_status": {
      "type": "string",
      "description": "Finding lifecycle state.",
      "enum": ["new", "enriched", "triaged", "ready", "reported", "acknowledged", "fixed", "published", "rejected", "duplicate"]
    },

    "contact_channel": {
      "type": "string",
      "enum": ["security_md", "ghsa", "security_txt", "email", "registry", "issue", "org_security"]
    },

    "fixaudit_status": {
      "type": "string",
      "enum": ["fixed", "bypass", "variant", "regressed"]
    },

    "trusted": {
      "type": "string",
      "enum": ["yes", "no", "conditional"]
    }
  }
}
